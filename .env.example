# App
PORT=3000
NODE_ENV=development

# Nomba API - TEST credentials (sandbox only)
NOMBA_CLIENT_ID=your_test_client_id
NOMBA_PRIVATE_KEY=your_test_private_key
NOMBA_ACCOUNT_ID=your_parent_account_id
NOMBA_SUB_ACCOUNT_ID=your_sub_account_id
NOMBA_BASE_URL=https://sandbox.nomba.com/v1
NOMBA_WEBHOOK_SECRET=your_webhook_secret

# Database (Supabase Postgres)
DATABASE_URL=postgresql://user:password@host:5432/postgres

# Redis (Memurai locally, Upstash in production)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=7d

# Resend (OTP emails)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=

# Checkout
CHECKOUT_CALLBACK_URL=http://localhost:3000/api/v1/checkout/callback

APP_NAME=VendHub
